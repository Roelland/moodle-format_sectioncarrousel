{{!
    @template core_courseformat/local/content

    Section Carrousel override: identical to the core content template except the
    section partial points to our format-specific section wrapper so the full
    card-layout template chain is triggered.
}}
<div id="course-format-{{uniqid}}">
    <h2 class="accesshide">{{{title}}}</h2>
    {{{completionhelp}}}
    <ul class="{{format}} section-list" data-for="course_sectionlist">
        {{#initialsection}}
            {{$ format_sectioncarrousel/local/content/section }}
                {{> format_sectioncarrousel/local/content/section }}
            {{/ format_sectioncarrousel/local/content/section }}
        {{/initialsection}}
        {{#sections}}
            {{$ format_sectioncarrousel/local/content/section }}
                {{> format_sectioncarrousel/local/content/section }}
            {{/ format_sectioncarrousel/local/content/section }}
        {{/sections}}
    </ul>
    {{#hasnavigation}}
    <div class="single-section">
        {{#sectionnavigation}}
            {{$ core_courseformat/local/content/sectionnavigation }}
                {{> core_courseformat/local/content/sectionnavigation }}
            {{/ core_courseformat/local/content/sectionnavigation }}
        {{/sectionnavigation}}
        <ul class="{{format}} section-list">
        {{#singlesection}}
            {{$ format_sectioncarrousel/local/content/section }}
                {{> format_sectioncarrousel/local/content/section }}
            {{/ format_sectioncarrousel/local/content/section }}
        {{/singlesection}}
        </ul>
        {{#sectionselector}}
            {{$ core_courseformat/local/content/sectionselector }}
                {{> core_courseformat/local/content/sectionselector }}
            {{/ core_courseformat/local/content/sectionselector }}
        {{/sectionselector}}
    </div>
    {{/hasnavigation}}
    {{#numsections}}
        {{^singlesection}}
            {{$ core_courseformat/local/content/addsection}}
                {{> core_courseformat/local/content/addsection}}
            {{/ core_courseformat/local/content/addsection}}
        {{/singlesection}}
    {{/numsections}}
    {{#bulkedittools}}
        {{$ core_courseformat/local/content/bulkedittools}}
            {{> core_courseformat/local/content/bulkedittools}}
        {{/ core_courseformat/local/content/bulkedittools}}
    {{/bulkedittools}}
</div>
{{$ core_courseformat/local/content-js}}
{{#js}}
require(['core_courseformat/local/content', 'format_sectioncarrousel/carrousel'], function(component, carrousel) {
    component.init(
        '#page', {}, {{sectionreturn}}, {{#pagesectionid}}{{.}}{{/pagesectionid}}{{^pagesectionid}}null{{/pagesectionid}}
    );
    carrousel.init();
});
{{/js}}
{{/ core_courseformat/local/content-js}}
