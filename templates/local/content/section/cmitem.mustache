{{!
    @template core_courseformat/local/content/section/cmitem

    Section Carrousel format: renders each course activity as a Bootstrap card.
    Card structure (top to bottom): icon image, activity title, mark-as-done button.

    Example context (json):
    {
        "id": 3,
        "anchor": "module-3",
        "module": "quiz",
        "extraclasses": "",
        "hasinfo": false,
        "indent": 0,
        "cardicon": "https://example.com/mod/quiz/pix/icon.svg",
        "cardiconclass": "",
        "cardiconpurpose": "assessment",
        "cmformat": {
            "activityname": "My Quiz",
            "url": "https://example.com/mod/quiz/view.php?id=3",
            "cmid": 3,
            "hasname": true,
            "hasurl": true,
            "editing": false,
            "completion": {
                "uservisible": true,
                "showmanualcompletion": true,
                "istrackeduser": true,
                "overallcomplete": false,
                "activityname": "My Quiz"
            }
        }
    }
}}
<li
    class="activity {{module}} modtype_{{module}} {{extraclasses}} {{#hasinfo}}hasinfo{{/hasinfo}} {{#indent}}indented{{/indent}} carrousel-card-item"
    id="{{anchor}}"
    data-for="cmitem"
    data-id="{{id}}"
>
    <div class="card h-100 shadow-sm carrousel-activity-card position-relative">

        {{! ── Card image-top: activity icon ── }}
        <div class="card-img-top carrousel-icon-top d-flex align-items-center justify-content-center {{cardiconpurpose}}">
            {{#cardicon}}
                <img
                    src="{{{cardicon}}}"
                    class="activityicon {{cardiconclass}} carrousel-icon"
                    alt=""
                    aria-hidden="true"
                >
            {{/cardicon}}
            {{^cardicon}}
                <span class="carrousel-icon-placeholder"></span>
            {{/cardicon}}
        </div>

        {{#cmformat}}

        {{! ── Card body: activity title ── }}
        <div class="card-body d-flex flex-column align-items-center justify-content-center text-center p-3">
            {{#hasname}}
            <h6 class="card-title mb-0 fw-semibold">
                {{#hasurl}}
                    <a href="{{{url}}}" class="aalink text-body stretched-link">{{activityname}}</a>
                {{/hasurl}}
                {{^hasurl}}
                    {{activityname}}
                {{/hasurl}}
            </h6>
            {{/hasname}}
        </div>

        {{! ── Card footer: completion (Mark as done) button ── }}
        {{#completion}}
        <div class="card-footer bg-transparent border-top text-center p-2 carrousel-completion position-relative" style="z-index: 2;">
            {{$ core_courseformat/local/content/cm/completion }}
                {{> core_courseformat/local/content/cm/completion }}
            {{/ core_courseformat/local/content/cm/completion }}
        </div>
        {{/completion}}

        {{! ── Edit mode: control menu pinned to top-right corner ── }}
        {{#editing}}
        {{#controlmenu}}
        <div class="position-absolute top-0 end-0 m-1" style="z-index: 3;">
            {{$ core_courseformat/local/content/cm/controlmenu }}
                {{> core_courseformat/local/content/cm/controlmenu }}
            {{/ core_courseformat/local/content/cm/controlmenu }}
        </div>
        {{/controlmenu}}
        {{/editing}}

        {{/cmformat}}
    </div>
</li>
