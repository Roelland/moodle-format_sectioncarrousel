{{!
    @template core_courseformat/local/content/section/cmlist

    Section Carrousel override: wraps the activity list in a flex-wrap container
    so each cmitem card flows into a responsive grid.

    Example context (json):
    {
        "cms": [{"cmitem": {"id": 3, "module": "forum", "anchor": "module-3", "extraclasses": ""}}],
        "hascms": true,
        "showmovehere": false,
        "movingstr": "",
        "cancelcopyurl": "#",
        "movetosectionurl": "#",
        "strmovefull": ""
    }
}}
{{#showmovehere}}
<p>{{movingstr}} (<a href="{{{cancelcopyurl}}}">{{#str}} cancel {{/str}}</a>)</p>
{{/showmovehere}}
<ul class="section img-text d-flex flex-wrap gap-3 p-0 m-0 list-unstyled carrousel-cmlist {{#hascms}}has-activities{{/hascms}}" data-for="cmlist">
{{#cms}}
    {{#showmovehere}}
    <li class="movehere">
        <a href="{{{moveurl}}}" title="{{strmovefull}}" class="movehere"></a>
    </li>
    {{/showmovehere}}
    {{#cmitem}}
        {{$ format_sectioncarrousel/local/content/section/cmitem}}
            {{> format_sectioncarrousel/local/content/section/cmitem}}
        {{/ format_sectioncarrousel/local/content/section/cmitem}}
    {{/cmitem}}
{{/cms}}
{{#showmovehere}}
    <li class="movehere">
        <a href="{{{movetosectionurl}}}" title="{{strmovefull}}" class="movehere"></a>
    </li>
{{/showmovehere}}
</ul>
