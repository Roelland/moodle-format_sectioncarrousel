{{!
    @template core_courseformat/local/content/section/cmlist

    Section Carrousel override — three rendering modes:
      editmode=true  → standard Moodle list (core cmitem, all edit controls intact)
      editmode=false, usecarousel=true  → scroll-snap carousel with card cmitem
      editmode=false, usecarousel=false → flex-wrap card grid with card cmitem

    Example context (json):
    {
        "cms": [
            {
                "cmitem": {
                    "id": 3,
                    "module": "forum",
                    "anchor": "module-3",
                    "extraclasses": ""
                }
            }
        ],
        "hascms": true,
        "showmovehere": false,
        "movingstr": "",
        "cancelcopyurl": "#",
        "movetosectionurl": "#",
        "strmovefull": "",
        "editmode": false,
        "usecarousel": false
    }
}}
{{#showmovehere}}
<p>{{movingstr}} (<a href="{{{cancelcopyurl}}}">{{#str}} cancel {{/str}}</a>)</p>
{{/showmovehere}}
{{#editmode}}
<ul class="section img-text" data-for="cmlist">
    {{#cms}}
        {{#showmovehere}}
        <li class="movehere">
            <a href="{{{moveurl}}}" title="{{strmovefull}}" class="movehere"></a>
        </li>
        {{/showmovehere}}
        {{#cmitem}}
            {{$ core_courseformat/local/content/section/cmitem}}
                {{> core_courseformat/local/content/section/cmitem}}
            {{/ core_courseformat/local/content/section/cmitem}}
        {{/cmitem}}
    {{/cms}}
    {{#showmovehere}}
    <li class="movehere">
        <a href="{{{movetosectionurl}}}" title="{{strmovefull}}" class="movehere"></a>
    </li>
    {{/showmovehere}}
</ul>
{{/editmode}}
{{^editmode}}
{{#usecarousel}}
<div class="carrousel-nav-wrapper">
    <div class="d-flex justify-content-end gap-2 mb-2">
        <button class="btn btn-outline-secondary btn-sm px-3 carrousel-prev-btn"
                type="button" aria-label="Previous">&#8249;</button>
        <button class="btn btn-outline-secondary btn-sm px-3 carrousel-next-btn"
                type="button" aria-label="Next">&#8250;</button>
    </div>
    <ul class="section img-text d-flex gap-3 p-0 py-2 m-0 list-unstyled carrousel-cmlist carrousel-scroll-container {{#hascms}}has-activities{{/hascms}}" data-for="cmlist">
        {{#cms}}
            {{#showmovehere}}
            <li class="movehere">
                <a href="{{{moveurl}}}" title="{{strmovefull}}" class="movehere"></a>
            </li>
            {{/showmovehere}}
            {{#cmitem}}
                {{$ format_sectioncarrousel/local/content/section/cmitem}}
                    {{> format_sectioncarrousel/local/content/section/cmitem}}
                {{/ format_sectioncarrousel/local/content/section/cmitem}}
            {{/cmitem}}
        {{/cms}}
        {{#showmovehere}}
        <li class="movehere">
            <a href="{{{movetosectionurl}}}" title="{{strmovefull}}" class="movehere"></a>
        </li>
        {{/showmovehere}}
    </ul>
</div>
{{/usecarousel}}
{{^usecarousel}}
<ul class="section img-text d-flex flex-wrap gap-3 p-0 m-0 list-unstyled carrousel-cmlist {{#hascms}}has-activities{{/hascms}}" data-for="cmlist">
{{#cms}}
    {{#showmovehere}}
    <li class="movehere">
        <a href="{{{moveurl}}}" title="{{strmovefull}}" class="movehere"></a>
    </li>
    {{/showmovehere}}
    {{#cmitem}}
        {{$ format_sectioncarrousel/local/content/section/cmitem}}
            {{> format_sectioncarrousel/local/content/section/cmitem}}
        {{/ format_sectioncarrousel/local/content/section/cmitem}}
    {{/cmitem}}
{{/cms}}
{{#showmovehere}}
    <li class="movehere">
        <a href="{{{movetosectionurl}}}" title="{{strmovefull}}" class="movehere"></a>
    </li>
{{/showmovehere}}
</ul>
{{/usecarousel}}
{{/editmode}}
